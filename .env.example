# Opportunity Radar - Environment Variables
# Copy this to .env and fill in your values

# Get free API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=sqlite+aiosqlite:///./opportunity_radar.db

# NSE Data Config
NSE_BASE_URL=https://www.nseindia.com
BSE_BASE_URL=https://api.bseindia.com/BseIndiaAPI/api

# Scheduling
SCAN_INTERVAL_MINUTES=30
SIGNAL_DETECTION_INTERVAL_MINUTES=15

# Alert Config
ALERT_MIN_CONFIDENCE=0.7
MAX_ALERTS_PER_DAY=50
